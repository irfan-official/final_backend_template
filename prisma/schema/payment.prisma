model Payment {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String?
  stripeSessionId String   @unique
  stripePaymentId String?
  amount          Int
  currency        String
  status          PaymentStatus @default(PENDING)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}